[global]
name=fs_bench
bs=256k
runtime=30s
time_based
group_reporting

[sequential_read_eight_threads]
size=100G
rw=read
ioengine=sync
fallocate=none
numjobs=8

[sequential_write_eight_threads]
new_group
numjobs=8
size=100G
rw=write
ioengine=sync
fallocate=none
create_on_open=1
fsync_on_close=1
unlink=1
